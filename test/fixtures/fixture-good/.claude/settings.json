{
  "permissions": {
    "allow": ["Bash(npm test *)", "Bash(npm run *)"],
    "deny": ["Bash(rm -rf *)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "echo formatting..." }]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "echo 'fixture status line'"
  }
}
